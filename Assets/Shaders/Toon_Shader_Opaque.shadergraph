    "m_FunctionBody": "#ifdef UNIVERSAL_LIGHTING_INCLUDED\n    Light light = GetMainLight();\n    Direction = light.direction;\n    Color = light.color;\n    ShadowAtten = light.shadowAttenuation;\n#else\n    Direction = float3(0.5, 0.5, 0);\n    Color = float3(1, 1, 1);\n    ShadowAtten = 1.0;\n#endif"
}

